# Hackathon Trading Agent — Environment Variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Sepolia Testnet (ERC-8004 Registration) ──────────────
# Required for on-chain agent identity registration and reputation updates.
# Get test ETH from: https://cloud.google.com/application/web3/faucet/ethereum/sepolia

SEPOLIA_PRIVATE_KEY=0x_your_private_key_here
SEPOLIA_WALLET_ADDRESS=0x_your_wallet_address_here

# RPC endpoint — use a public node or your own Infura/Alchemy key
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
# Or with Infura: SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ── Optional ─────────────────────────────────────────────
# INFURA_KEY=your_infura_key_here
